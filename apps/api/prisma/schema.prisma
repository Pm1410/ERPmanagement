generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id             String            @id @default(uuid())
  name           String
  logo           String?
  address        String?
  phone          String?
  email          String?
  website        String?
  board          String?
  affiliationNo  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  academicYears  AcademicYear[]
  assignments    Assignment[]
  books          Book[]
  bookIssues     BookIssue[]
  classes        Class[]
  exams          Exam[]
  examSchedules  ExamSchedule[]
  faculty        Faculty[]
  feeConcessions FeeConcession[]
  feeHeads       FeeHead[]
  feePayments    FeePayment[]
  feeStructures  FeeStructure[]
  grievances     Grievance[]
  holidays       Holiday[]
  hostelRooms    HostelRoom[]
  hostelAllocations HostelAllocation[]
  transportVehicles TransportVehicle[]
  transportRoutes   TransportRoute[]
  transportAssignments TransportAssignment[]
  studyMaterials StudyMaterial[]
  parents        Parent[]
  parentStudents ParentStudent[]
  messages       Message[]
  notices        Notice[]
  notifLogs      NotificationLog[]
  payrollConfigs PayrollConfig[]
  payslips       Payslip[]
  staffLeaves    StaffLeave[]
  students       Student[]
  subjects       Subject[]
  timetableSlots TimetableSlot[]
  users          User[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  name               String
  avatar             String?
  phone              String?
  roleId             String
  institutionId      String?
  isActive           Boolean             @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  auditLogs          AuditLog[]
  facultyMembers     Faculty?
  grievancesAssigned Grievance[]         @relation("GrievanceAssigned")
  inAppNotifications InAppNotification[]
  receivedMessages   Message[]           @relation("ReceivedMessages")
  sentMessages       Message[]           @relation("SentMessages")
  noticesAuthor      Notice[]
  noticeReads        NoticeRead[]
  staffLeaves        StaffLeave[]
  students           Student?
  studyMaterials     StudyMaterial[]
  parent             Parent?
  institution        Institution?        @relation(fields: [institutionId], references: [id])
  role               Role                @relation(fields: [roleId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entity     String
  entityId   String?
  payload    String?
  ipAddress  String?
  userAgent  String?
  durationMs Int?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model AcademicYear {
  id             String          @id @default(uuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean         @default(false)
  institutionId  String
  createdAt      DateTime        @default(now())
  institution    Institution     @relation(fields: [institutionId], references: [id])
  classes        Class[]
  exams          Exam[]
  feeStructures  FeeStructure[]
  timetableSlots TimetableSlot[]
}

model Class {
  id                 String              @id @default(uuid())
  name               String
  orderIndex         Int                 @default(0)
  academicYearId     String
  institutionId      String
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  assignments        Assignment[]
  attendanceRecords  AttendanceRecord[]
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id])
  institution        Institution         @relation(fields: [institutionId], references: [id])
  examSchedules      ExamSchedule[]
  facultyAssignments FacultyAssignment[]
  feeStructures      FeeStructure[]
  grades             Grade[]
  sections           Section[]
  students           Student[]
  subjects           Subject[]
  timetableSlots     TimetableSlot[]
  studyMaterials     StudyMaterial[]
}

model Section {
  id                 String              @id @default(uuid())
  name               String
  classId            String
  classTeacherId     String?
  maxStrength        Int                 @default(60)
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  assignments        Assignment[]
  attendanceRecords  AttendanceRecord[]
  examSchedules      ExamSchedule[]
  facultyAssignments FacultyAssignment[]
  grades             Grade[]
  class              Class               @relation(fields: [classId], references: [id])
  classTeacher       Faculty?            @relation(fields: [classTeacherId], references: [id])
  students           Student[]
  timetableSlots     TimetableSlot[]
  studyMaterials     StudyMaterial[]
}

model Subject {
  id                 String              @id @default(uuid())
  name               String
  code               String?
  type               String              @default("THEORY")
  classId            String
  institutionId      String
  weeklyPeriods      Int                 @default(5)
  maxMarks           Int                 @default(100)
  passMarks          Int                 @default(35)
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  assignments        Assignment[]
  attendanceRecords  AttendanceRecord[]
  examSchedules      ExamSchedule[]
  facultyAssignments FacultyAssignment[]
  grades             Grade[]
  class              Class               @relation(fields: [classId], references: [id])
  institution        Institution         @relation(fields: [institutionId], references: [id])
  timetableSlots     TimetableSlot[]
  studyMaterials     StudyMaterial[]
}

model TimetableSlot {
  id             String       @id @default(uuid())
  day            String
  startTime      String
  endTime        String
  classId        String
  sectionId      String
  subjectId      String
  facultyId      String
  academicYearId String
  room           String?
  institutionId  String
  createdAt      DateTime     @default(now())
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  faculty        Faculty      @relation(fields: [facultyId], references: [id])
  institution    Institution  @relation(fields: [institutionId], references: [id])
  section        Section      @relation(fields: [sectionId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
}

model Student {
  id                String                 @id @default(uuid())
  userId            String?                @unique
  institutionId     String
  name              String
  email             String?
  phone             String?
  dateOfBirth       DateTime
  gender            String
  bloodGroup        String?
  religion          String?
  category          String?
  nationality       String?
  address           String?
  permanentAddress  String?
  fatherName        String?
  fatherPhone       String?
  fatherOccupation  String?
  motherName        String?
  motherPhone       String?
  guardianName      String?
  guardianPhone     String?
  parentEmail       String?
  classId           String
  sectionId         String
  admissionNumber   String?                @unique
  rollNumber        String?
  isActive          Boolean                @default(true)
  avatar            String?
  deletedAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  submissions       AssignmentSubmission[]
  attendanceRecords AttendanceRecord[]
  bookIssues        BookIssue[]
  feeConcessions    FeeConcession[]
  feePayments       FeePayment[]
  grades            Grade[]
  grievances        Grievance[]
  leaveRequests     LeaveRequest[]
  class             Class                  @relation(fields: [classId], references: [id])
  institution       Institution            @relation(fields: [institutionId], references: [id])
  section           Section                @relation(fields: [sectionId], references: [id])
  user              User?                  @relation(fields: [userId], references: [id])
  documents         StudentDocument[]
  hostelAllocations HostelAllocation[]
  transportAssignments TransportAssignment[]
  parents          ParentStudent[]
}

model Parent {
  id            String      @id @default(uuid())
  institutionId String
  userId        String      @unique
  name          String
  email         String
  phone         String?
  isActive      Boolean     @default(true)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  students      ParentStudent[]

  @@index([institutionId, isActive])
}

model ParentStudent {
  id            String     @id @default(uuid())
  institutionId String
  parentId      String
  studentId     String
  relation      String?    // FATHER/MOTHER/GUARDIAN
  isPrimary     Boolean    @default(false)
  createdAt     DateTime   @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id])
  parent        Parent      @relation(fields: [parentId], references: [id])
  student       Student     @relation(fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@index([institutionId, parentId])
  @@index([institutionId, studentId])
}

// ─── Transport ────────────────────────────────────────────────
model TransportVehicle {
  id            String      @id @default(uuid())
  institutionId String
  vehicleNo     String
  type          String      @default("BUS") // BUS/VAN
  capacity      Int         @default(40)
  driverName    String?
  driverPhone   String?
  isActive      Boolean     @default(true)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  routes        TransportRoute[]

  @@unique([institutionId, vehicleNo])
}

model TransportRoute {
  id            String      @id @default(uuid())
  institutionId String
  name          String
  vehicleId     String?
  isActive      Boolean     @default(true)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution      @relation(fields: [institutionId], references: [id])
  vehicle       TransportVehicle? @relation(fields: [vehicleId], references: [id])
  stops         TransportStop[]
  assignments   TransportAssignment[]

  @@unique([institutionId, name])
}

model TransportStop {
  id        String      @id @default(uuid())
  routeId   String
  name      String
  order     Int         @default(0)
  pickupTime String?
  dropTime   String?
  createdAt DateTime    @default(now())

  route     TransportRoute @relation(fields: [routeId], references: [id])
  assignments TransportAssignment[]

  @@index([routeId, order])
}

model TransportAssignment {
  id            String      @id @default(uuid())
  institutionId String
  studentId     String
  routeId       String
  stopId        String?
  startDate     DateTime    @default(now())
  endDate       DateTime?
  status        String      @default("ACTIVE")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution     @relation(fields: [institutionId], references: [id])
  student       Student         @relation(fields: [studentId], references: [id])
  route         TransportRoute  @relation(fields: [routeId], references: [id])
  stop          TransportStop?  @relation(fields: [stopId], references: [id])

  @@index([institutionId, status])
  @@index([studentId, status])
}

// ─── Hostel ───────────────────────────────────────────────────
model HostelRoom {
  id            String      @id @default(uuid())
  institutionId String
  name          String      // e.g. "A-101"
  hostelName    String      @default("Main Hostel")
  floor         Int?        @default(1)
  roomType      String      @default("SHARED") // SINGLE/DOUBLE/SHARED
  capacity      Int         @default(4)
  isActive      Boolean     @default(true)
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  allocations   HostelAllocation[]

  @@unique([institutionId, name])
  @@index([institutionId, isActive])
}

model HostelAllocation {
  id            String     @id @default(uuid())
  institutionId String
  studentId     String
  roomId        String
  bedNo         String?    // optional; "1", "B2", etc.
  startDate     DateTime   @default(now())
  endDate       DateTime?
  status        String     @default("ACTIVE") // ACTIVE/VACATED
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  student       Student     @relation(fields: [studentId], references: [id])
  room          HostelRoom  @relation(fields: [roomId], references: [id])

  @@index([institutionId, status])
  @@index([studentId, status])
}

model StudentDocument {
  id         String   @id @default(uuid())
  studentId  String
  docType    String
  fileName   String
  fileKey    String
  fileUrl    String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id])
}

model Faculty {
  id                         String              @id @default(uuid())
  userId                     String?             @unique
  institutionId              String
  name                       String
  email                      String
  phone                      String?
  dateOfBirth                DateTime?
  gender                     String?
  qualification              String?
  specialization             String?
  experience                 Int                 @default(0)
  employmentType             String              @default("FULL_TIME")
  designation                String?
  department                 String?
  joiningDate                DateTime?
  address                    String?
  emergencyContact           String?
  isActive                   Boolean             @default(true)
  avatar                     String?
  deletedAt                  DateTime?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  assignmentsCreated         Assignment[]
  examSchedulesAsInvigilator ExamSchedule[]
  institution                Institution         @relation(fields: [institutionId], references: [id])
  user                       User?               @relation(fields: [userId], references: [id])
  assignments                FacultyAssignment[]
  payrollConfig              PayrollConfig?
  payslips                   Payslip[]
  classTeacher               Section[]
  contracts                  StaffContract[]
  staffLeaves                StaffLeave[]        @relation("FacultyLeaves")
  timetableSlots             TimetableSlot[]
  studyMaterials             StudyMaterial[]
}

// ─── Study Materials ───────────────────────────────────────────
model StudyMaterial {
  id            String      @id @default(uuid())
  institutionId String
  uploadedById  String
  facultyId     String?
  title         String
  description   String?
  classId       String
  sectionId     String?
  subjectId     String?
  fileName      String
  fileKey       String
  fileUrl       String
  isActive      Boolean     @default(true)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id])
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  faculty       Faculty?    @relation(fields: [facultyId], references: [id])
  class         Class       @relation(fields: [classId], references: [id])
  section       Section?    @relation(fields: [sectionId], references: [id])
  subject       Subject?    @relation(fields: [subjectId], references: [id])

  @@index([institutionId, classId, createdAt])
  @@index([uploadedById, createdAt])
}

model FacultyAssignment {
  id             String   @id @default(uuid())
  facultyId      String
  subjectId      String
  classId        String
  sectionId      String
  academicYearId String
  createdAt      DateTime @default(now())
  class          Class    @relation(fields: [classId], references: [id])
  faculty        Faculty  @relation(fields: [facultyId], references: [id])
  section        Section  @relation(fields: [sectionId], references: [id])
  subject        Subject  @relation(fields: [subjectId], references: [id])
}

model AttendanceRecord {
  id             String   @id @default(uuid())
  studentId      String
  classId        String
  sectionId      String
  subjectId      String
  academicYearId String
  date           DateTime
  status         String
  remarks        String?
  markedById     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  class          Class    @relation(fields: [classId], references: [id])
  section        Section  @relation(fields: [sectionId], references: [id])
  student        Student  @relation(fields: [studentId], references: [id])
  subject        Subject  @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, date])
  @@index([classId, sectionId, date])
  @@index([studentId, date])
}

model LeaveRequest {
  id              String   @id @default(uuid())
  studentId       String
  leaveType       String
  fromDate        DateTime
  toDate          DateTime
  reason          String
  status          String   @default("PENDING")
  approverId      String?
  approverRemarks String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id])
}

model Exam {
  id             String         @id @default(uuid())
  name           String
  examType       String
  academicYearId String
  institutionId  String
  startDate      DateTime?
  endDate        DateTime?
  description    String?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  institution    Institution    @relation(fields: [institutionId], references: [id])
  schedules      ExamSchedule[]
  grades         Grade[]
}

model ExamSchedule {
  id            String      @id @default(uuid())
  examId        String
  classId       String
  sectionId     String
  subjectId     String
  date          DateTime
  startTime     String
  endTime       String
  venue         String?
  invigilatorId String?
  maxMarks      Int         @default(100)
  passMarks     Int?
  isFinalized   Boolean     @default(false)
  institutionId String
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  class         Class       @relation(fields: [classId], references: [id])
  exam          Exam        @relation(fields: [examId], references: [id])
  institution   Institution @relation(fields: [institutionId], references: [id])
  invigilator   Faculty?    @relation(fields: [invigilatorId], references: [id])
  section       Section     @relation(fields: [sectionId], references: [id])
  subject       Subject     @relation(fields: [subjectId], references: [id])
  grades        Grade[]
}

model Grade {
  id             String       @id @default(uuid())
  studentId      String
  examId         String
  examScheduleId String
  subjectId      String
  classId        String
  sectionId      String
  maxMarks       Int
  marksObtained  Decimal      @db.Decimal(6, 2)
  grade          String?
  isPassed       Boolean      @default(false)
  remarks        String?
  enteredById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  class          Class        @relation(fields: [classId], references: [id])
  exam           Exam         @relation(fields: [examId], references: [id])
  examSchedule   ExamSchedule @relation(fields: [examScheduleId], references: [id])
  section        Section      @relation(fields: [sectionId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examScheduleId])
  @@index([classId, sectionId, examId])
}

model FeeHead {
  id             String             @id @default(uuid())
  name           String
  description    String?
  isOptional     Boolean            @default(false)
  institutionId  String
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  institution    Institution        @relation(fields: [institutionId], references: [id])
  payments       FeePayment[]
  structureItems FeeStructureItem[]
  concessions    FeeConcession[]    @relation("FeeConcessionToFeeHead")
}

model FeeStructure {
  id             String             @id @default(uuid())
  classId        String
  academicYearId String
  institutionId  String
  frequency      String             @default("ANNUAL")
  lateFeePerDay  Decimal?           @db.Decimal(8, 2)
  dueDate        DateTime?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  academicYear   AcademicYear       @relation(fields: [academicYearId], references: [id])
  class          Class              @relation(fields: [classId], references: [id])
  institution    Institution        @relation(fields: [institutionId], references: [id])
  items          FeeStructureItem[]
}

model FeeStructureItem {
  id             String       @id @default(uuid())
  feeStructureId String
  feeHeadId      String
  amount         Decimal      @db.Decimal(10, 2)
  feeHead        FeeHead      @relation(fields: [feeHeadId], references: [id])
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
}

model FeePayment {
  id               String      @id @default(uuid())
  studentId        String
  feeHeadId        String
  amount           Decimal     @db.Decimal(10, 2)
  paymentMode      String
  referenceNumber  String?
  receiptNumber    String
  gatewayOrderId   String?
  gatewayPaymentId String?
  status           String      @default("PENDING")
  paidAt           DateTime?
  collectedById    String?
  institutionId    String
  remarks          String?
  createdAt        DateTime    @default(now())
  feeHead          FeeHead     @relation(fields: [feeHeadId], references: [id])
  institution      Institution @relation(fields: [institutionId], references: [id])
  student          Student     @relation(fields: [studentId], references: [id])

  @@index([studentId, status])
}

model FeeConcession {
  id             String      @id @default(uuid())
  studentId      String
  reason         String
  concessionType String
  value          Decimal     @db.Decimal(8, 2)
  feeHeadIds     String[]
  approvedById   String?
  institutionId  String
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  institution    Institution @relation(fields: [institutionId], references: [id])
  student        Student     @relation(fields: [studentId], references: [id])
  feeHeads       FeeHead[]   @relation("FeeConcessionToFeeHead")
}

model Assignment {
  id             String                 @id @default(uuid())
  title          String
  instructions   String?
  classId        String
  sectionId      String
  subjectId      String
  facultyId      String
  dueDate        DateTime
  maxMarks       Int?
  submissionType String                 @default("BOTH")
  institutionId  String
  deletedAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  class          Class                  @relation(fields: [classId], references: [id])
  faculty        Faculty                @relation(fields: [facultyId], references: [id])
  institution    Institution            @relation(fields: [institutionId], references: [id])
  section        Section                @relation(fields: [sectionId], references: [id])
  subject        Subject                @relation(fields: [subjectId], references: [id])
  submissions    AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String     @id @default(uuid())
  assignmentId  String
  studentId     String
  textContent   String?
  fileKey       String?
  fileUrl       String?
  submittedAt   DateTime
  status        String     @default("SUBMITTED")
  marksObtained Decimal?   @db.Decimal(6, 2)
  feedback      String?
  gradedById    String?
  gradedAt      DateTime?
  createdAt     DateTime   @default(now())
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  student       Student    @relation(fields: [studentId], references: [id])
}

model Book {
  id              String      @id @default(uuid())
  title           String
  author          String
  isbn            String?
  publisher       String?
  edition         String?
  publishYear     Int?
  category        String?
  language        String      @default("English")
  description     String?
  totalCopies     Int         @default(1)
  availableCopies Int         @default(1)
  institutionId   String
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  institution     Institution @relation(fields: [institutionId], references: [id])
  issues          BookIssue[]
}

model BookIssue {
  id              String      @id @default(uuid())
  bookId          String
  studentId       String
  issuedById      String
  dueDate         DateTime
  returnedAt      DateTime?
  returnedById    String?
  returnCondition String?
  fine            Decimal     @default(0) @db.Decimal(8, 2)
  institutionId   String
  createdAt       DateTime    @default(now())
  book            Book        @relation(fields: [bookId], references: [id])
  institution     Institution @relation(fields: [institutionId], references: [id])
  student         Student     @relation(fields: [studentId], references: [id])
}

model Notice {
  id            String       @id @default(uuid())
  title         String
  body          String
  priority      String       @default("NORMAL")
  category      String       @default("GENERAL")
  target        String
  classId       String?
  sectionId     String?
  authorId      String
  institutionId String
  isPublished   Boolean      @default(true)
  scheduledAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  author        User         @relation(fields: [authorId], references: [id])
  institution   Institution  @relation(fields: [institutionId], references: [id])
  reads         NoticeRead[]
}

model NoticeRead {
  noticeId String
  userId   String
  readAt   DateTime @default(now())
  notice   Notice   @relation(fields: [noticeId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([noticeId, userId])
}

model Message {
  id              String      @id @default(uuid())
  senderId        String
  recipientId     String
  body            String
  parentMessageId String?
  isRead          Boolean     @default(false)
  institutionId   String
  createdAt       DateTime    @default(now())
  institution     Institution @relation(fields: [institutionId], references: [id])
  parentMessage   Message?    @relation("ThreadMessages", fields: [parentMessageId], references: [id])
  replies         Message[]   @relation("ThreadMessages")
  recipient       User        @relation("ReceivedMessages", fields: [recipientId], references: [id])
  sender          User        @relation("SentMessages", fields: [senderId], references: [id])
}

model Grievance {
  id            String      @id @default(uuid())
  ticketNumber  String      @unique
  category      String
  title         String
  description   String
  status        String      @default("OPEN")
  isAnonymous   Boolean     @default(false)
  submittedById String?
  assignedToId  String?
  resolution    String?
  remarks       String?
  institutionId String
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  assignedTo    User?       @relation("GrievanceAssigned", fields: [assignedToId], references: [id])
  institution   Institution @relation(fields: [institutionId], references: [id])
  submittedBy   Student?    @relation(fields: [submittedById], references: [id])
}

model StaffLeave {
  id              String      @id @default(uuid())
  staffUserId     String
  institutionId   String
  leaveType       String
  fromDate        DateTime
  toDate          DateTime
  days            Int
  reason          String
  substituteId    String?
  status          String      @default("PENDING")
  approverId      String?
  approverRemarks String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  institution     Institution @relation(fields: [institutionId], references: [id])
  staff           User        @relation(fields: [staffUserId], references: [id])
  substitute      Faculty?    @relation("FacultyLeaves", fields: [substituteId], references: [id])
}

model PayrollConfig {
  id                   String      @id @default(uuid())
  staffId              String      @unique
  institutionId        String
  basicSalary          Decimal     @db.Decimal(12, 2)
  hra                  Decimal?    @db.Decimal(12, 2)
  ta                   Decimal?    @db.Decimal(12, 2)
  da                   Decimal?    @db.Decimal(12, 2)
  pf                   Decimal?    @db.Decimal(12, 2)
  esi                  Decimal?    @db.Decimal(12, 2)
  tds                  Decimal?    @db.Decimal(12, 2)
  professionalTax      Decimal?    @db.Decimal(12, 2)
  additionalComponents Json?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  institution          Institution @relation(fields: [institutionId], references: [id])
  staff                Faculty     @relation(fields: [staffId], references: [id])
}

model Payslip {
  id              String      @id @default(uuid())
  staffId         String
  institutionId   String
  month           Int
  year            Int
  basicSalary     Decimal     @db.Decimal(12, 2)
  hra             Decimal     @default(0) @db.Decimal(12, 2)
  ta              Decimal     @default(0) @db.Decimal(12, 2)
  da              Decimal     @default(0) @db.Decimal(12, 2)
  grossEarnings   Decimal     @db.Decimal(12, 2)
  pf              Decimal     @default(0) @db.Decimal(12, 2)
  esi             Decimal     @default(0) @db.Decimal(12, 2)
  tds             Decimal     @default(0) @db.Decimal(12, 2)
  professionalTax Decimal     @default(0) @db.Decimal(12, 2)
  lopDeduction    Decimal     @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal     @db.Decimal(12, 2)
  netSalary       Decimal     @db.Decimal(12, 2)
  lopDays         Int         @default(0)
  workingDays     Int         @default(0)
  status          String      @default("GENERATED")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  institution     Institution @relation(fields: [institutionId], references: [id])
  staff           Faculty     @relation(fields: [staffId], references: [id])

  @@unique([staffId, month, year])
}

model Holiday {
  id            String      @id @default(uuid())
  name          String
  date          DateTime
  type          String      @default("NATIONAL")
  institutionId String
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id])
}

model StaffContract {
  id        String   @id @default(uuid())
  facultyId String
  startDate DateTime
  endDate   DateTime
  type      String
  fileKey   String?
  createdAt DateTime @default(now())
  faculty   Faculty  @relation(fields: [facultyId], references: [id])
}

model NotificationLog {
  id            String       @id @default(uuid())
  channel       String
  recipient     String
  subject       String?
  body          String
  status        String       @default("PENDING")
  sentAt        DateTime?
  errorMessage  String?
  institutionId String?
  createdAt     DateTime     @default(now())
  institution   Institution? @relation(fields: [institutionId], references: [id])
}

model AdmissionEnquiry {
  id              String   @id @default(uuid())
  parentName      String
  parentPhone     String
  childName       String
  classInterested String
  source          String   @default("WALK_IN")
  status          String   @default("NEW")
  institutionId   String
  createdAt       DateTime @default(now())
}

model AdmissionApplication {
  id            String   @id @default(uuid())
  applicationNo String   @unique
  studentName   String
  dateOfBirth   DateTime
  classApplied  String
  status        String   @default("PENDING")
  institutionId String
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScheduledReport {
  id              String    @id @default(uuid())
  name            String
  entity          String
  fields          String[]
  filters         String?
  format          String    @default("EXCEL")
  cronExpression  String
  emailRecipients String[]
  createdById     String
  institutionId   String
  isActive        Boolean   @default(true)
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ExportLog {
  id            String    @id @default(uuid())
  entity        String
  format        String
  fileName      String
  fileKey       String
  rowCount      Int       @default(0)
  institutionId String
  status        String    @default("PENDING")
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
}

model InAppNotification {
  id            String    @id @default(uuid())
  userId        String
  template      String
  title         String
  body          String
  isRead        Boolean   @default(false)
  readAt        DateTime?
  metadata      String?
  institutionId String
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}
