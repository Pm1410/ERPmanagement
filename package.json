{
  "name": "school-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade ERP School Management System (monorepo)",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build:api": "cd apps/api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "test": "cd apps/api && npm test",
    "test:coverage": "cd apps/api && npm run test:coverage",
    "lint": "cd apps/api && npm run lint",
    "db:generate": "cd apps/api && npm run db:generate",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed",
    "db:studio": "cd apps/api && npm run db:studio",
    "docker:up": "PYTHONNOUSERSITE=1 docker-compose up -d",
    "docker:down": "PYTHONNOUSERSITE=1 docker-compose down",
    "docker:logs": "PYTHONNOUSERSITE=1 docker-compose logs -f",
    "docker:reset": "PYTHONNOUSERSITE=1 docker-compose down -v && PYTHONNOUSERSITE=1 docker-compose up -d",
    "setup": "npm install && cd apps/api && npm install && npx prisma generate"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "dependencies": {
    "asynckit": "^0.4.0",
    "hasown": "^2.0.2",
    "mime-db": "^1.54.0",
    "postcss-nested": "^7.0.2",
    "postcss-selector-parser": "^7.1.1",
    "rxjs": "^7.8.2",
    "safer-buffer": "^2.1.2",
    "tailwindcss-animate": "^1.0.7"
  }
}
